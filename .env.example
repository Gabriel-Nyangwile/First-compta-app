# PostgreSQL connection string used by Prisma.
# On Vercel, set this in Project Settings > Environment Variables.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Optional app URL used by PDF/export helpers and absolute URLs.
NEXT_PUBLIC_APP_URL="https://your-project.vercel.app"

# API mutation/export token. Keep ADMIN_TOKEN server-side only.
ADMIN_TOKEN="change-me"
NEXT_PUBLIC_ADMIN_TOKEN="change-me-only-if-client-token-is-required"

# One-time bootstrap for the first platform administrator.
PLATFORM_ADMIN_EMAIL="admin@example.com"
PLATFORM_ADMIN_PASSWORD="change-me"
PLATFORM_ADMIN_USERNAME="platform-admin"

# Default company context for multi-company data.
DEFAULT_COMPANY_ID=""
DEFAULT_COMPANY_CURRENCY="CDF"

# Public onboarding demo company. DEMO_COMPANY_ID is preferred when set.
DEMO_COMPANY_ID=""
DEMO_COMPANY_NAME="Strategic Business Démo"

# Company details used in generated PDFs.
COMPANY_NAME=""
COMPANY_ADDRESS=""
COMPANY_SIRET=""
COMPANY_VAT=""

# Dev-only overrides for local RBAC testing.
AUTH_DEV_MODE=1
NEXT_PUBLIC_AUTH_DEV_MODE=1
